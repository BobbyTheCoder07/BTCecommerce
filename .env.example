# Django Settings
SECRET_KEY=django-insecure-your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Defaults to SQLite if DATABASE_URL is not provided or empty)
# Example PostgreSQL URL: postgresql://db_user:db_password@localhost:5432/btc_ecommerce
DATABASE_URL=

# Razorpay API Credentials (for product checkout payments)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# UPI Payments Configuration
UPI_ID=bobbythecoder@upi
UPI_MERCHANT_NAME=BobbyTheCoder

# Email Settings (for registration alerts / order invoices)
# In development, emails are printed to the console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_app_password
